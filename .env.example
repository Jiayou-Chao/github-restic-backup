# Example .env file for github-restic-backup.sh
# Copy this file to `.env` and fill in your personal values.
# Do NOT commit your `.env` file to version control.

# GitHub username to back up
GITHUB_USER=your-github-username

# Path to file containing your GitHub Personal Access Token (read-only, 1 line)
GITHUB_TOKEN_FILE=$HOME/.github_pat

# Directory to store local git mirrors
MIRRORS_DIR=$HOME/github-mirrors

# Restic repository.
# Can be a local path (e.g., /srv/restic-repo) or an rclone remote.
# Example for rclone: "rclone:myremote:restic-github-backup"
# Example for local path: "/path/to/your/backup/repo"
RESTIC_REPO=/path/to/your/backup/repo

# Path to file containing your restic password (read-only, 1 line)
RESTIC_PASSWORD_FILE=$HOME/.restic_pass

# Retention policy for restic snapshots
RESTIC_KEEP_DAILY=7
RESTIC_KEEP_WEEKLY=4
RESTIC_KEEP_MONTHLY=6

# Number of parallel jobs for git fetch (tune as needed)
PARALLEL_JOBS=4